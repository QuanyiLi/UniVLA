#!/bin/bash
#SBATCH --job-name=univla_eval
#SBATCH --output=/home/lfeng/task_logs/%A_%a.log
#SBATCH --partition=h100
#SBATCH --qos=vita
#SBATCH --array=0-11
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=8
#SBATCH --gpus-per-node=1
#SBATCH --nodes=1
#SBATCH --time=12:00:00
#SBATCH --mem=100G

# ============================================================
# Evaluate fine-tuned UniVLA model on all 24 subsets (train+test)
# using 12 nodes (1 H100 each), 2 configs per node.
#
# Array index 0..11 → configs [2*i, 2*i+2)
# After all array tasks finish, run aggregation separately:
#   python univla_eval.py --aggregate_only=true --result_dir=<RESULT_DIR>
# ============================================================

SCRIPT_PATH="/work/vita/lanfeng/vlas/UniVLA/scripts/univla_eval.py"
RESULT_DIR="/work/vita/lanfeng/vlas/univla_eval_result"
mkdir -p $RESULT_DIR

# UniVLA-specific paths
CHECKPOINT="/work/vita/lanfeng/vlas/exp_results/univla_finetune"
ACTION_DECODER="${CHECKPOINT}/action_decoder-40000.pt"
DATASET_NAME="maniskill_dataset_converted_externally_to_rlds"
WINDOW_SIZE=20

# Compute subset range from array task ID
START=$((SLURM_ARRAY_TASK_ID * 2))
END=$((START + 2))

echo "Array task ${SLURM_ARRAY_TASK_ID}: evaluating configs ${START} to $((END - 1))"

python $SCRIPT_PATH \
    --pretrained_checkpoint=$CHECKPOINT \
    --action_decoder_path=$ACTION_DECODER \
    --dataset_name=$DATASET_NAME \
    --window_size=$WINDOW_SIZE \
    --center_crop=true \
    --start_subset=$START \
    --end_subset=$END \
    --split=both \
    --eval_rounds=1 \
    --result_dir=$RESULT_DIR

echo "Array task ${SLURM_ARRAY_TASK_ID} done."
