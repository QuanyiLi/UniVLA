#!/bin/bash
#SBATCH --job-name=univla_eval
#SBATCH --output=/home/lfeng/task_logs/%j.log
#SBATCH --partition=h100
#SBATCH --qos=vita
#SBATCH --ntasks-per-node=4
#SBATCH --cpus-per-task=8
#SBATCH --gpus-per-node=4
#SBATCH --nodes=1
#SBATCH --time=12:00:00
#SBATCH --mem=100G

# ============================================================
# Evaluate fine-tuned UniVLA model on all 24 subsets (train+test)
# using 4 GPUs on 1 H100 node.
# ============================================================

SCRIPT_PATH="/work/vita/lanfeng/vlas/UniVLA/scripts/univla_eval.py"
RESULT_DIR="/work/vita/lanfeng/vlas/univla_eval_result"
mkdir -p $RESULT_DIR

# UniVLA-specific paths
CHECKPOINT="/work/vita/lanfeng/vlas/exp_results/univla_finetune/univla-7b+wiser_panda+b8+lr-0.00035+lora-r64+dropout-0.0--image_aug=w-LowLevelDecoder-ws-20"
ACTION_DECODER="${CHECKPOINT}/action_decoder-36000.pt"
DATASET_NAME="maniskill_dataset_converted_externally_to_rlds"
WINDOW_SIZE=20
SAVE_VIDEO=false

# Prevent SLURM's CUDA_VISIBLE_DEVICES from interfering with per-process GPU assignment
unset CUDA_VISIBLE_DEVICES

# Launch 4 processes, one per GPU, each handling 6 subsets
# Stagger launches by 60s to avoid simultaneous model loading OOM / cuDNN init failure
for GPU_ID in 0 1 2 3; do
    START=$((GPU_ID * 6))
    END=$(((GPU_ID + 1) * 6))

    CUDA_VISIBLE_DEVICES=$GPU_ID python $SCRIPT_PATH \
        --pretrained_checkpoint=$CHECKPOINT \
        --action_decoder_path=$ACTION_DECODER \
        --dataset_name=$DATASET_NAME \
        --window_size=$WINDOW_SIZE \
        --center_crop=true \
        --start_subset=$START \
        --end_subset=$END \
        --split=both \
        --eval_rounds=1 \
        --save_video=$SAVE_VIDEO \
        --result_dir=$RESULT_DIR \
        > "${RESULT_DIR}/gpu_${GPU_ID}.log" 2>&1 &

    echo "Launched GPU $GPU_ID: subsets $START to $((END - 1))"

    # Wait before launching the next process so models load one at a time
    if [ $GPU_ID -lt 3 ]; then
        sleep 5
    fi
done

echo "Waiting for all 4 GPU processes to finish..."
wait
echo "All rollouts complete."

# Final aggregation
echo "Running final aggregation..."
python $SCRIPT_PATH \
    --aggregate_only=true \
    --result_dir=$RESULT_DIR

echo "Done. Results in $RESULT_DIR"
